# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/apex_pulse?schema=public"

# ---------------------------------------------------------------------------
# AUTH / JWT
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET="replace-with-a-long-random-string-min-32-chars"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
COOKIE_DOMAIN="localhost"

# ---------------------------------------------------------------------------
# APP
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ---------------------------------------------------------------------------
# EMAIL (Resend primary, Nodemailer/SMTP fallback)
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Apex Pulse <no-reply@apexpulse.com>"
ADMIN_EMAIL="admin@apexpulse.com"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# ---------------------------------------------------------------------------
# FILE STORAGE (Cloudinary) — used from Phase 3 onward
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ---------------------------------------------------------------------------
# PAYMENTS — used from Phase 5 onward
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# RATE LIMITING / SECURITY
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX="100"
